# Claude Monitor configuration
# Port the server listens on (and the port hooks POST to).
PORT=2202

# Context-window size, used to show "X tokens left" on each card.
# 200000 for standard Claude, 1000000 for [1m] models (e.g. Opus 4.8 1M).
CONTEXT_LIMIT=1000000

# Plan usage (the `/usage` numbers: 5-hour + weekly limits). macOS only — reads
# the Claude Code OAuth token from the Keychain. Set false to disable.
TRACK_USAGE=true
USAGE_POLL_SEC=60
